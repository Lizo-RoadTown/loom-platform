# Copy to .env and fill in. .env is gitignored.

# Project Registry — your project's slug, registered with the-loom
LOOM_PROJECT_ID=loom-platform

# OTel telemetry — copy these values from the-loom's .env on your machine
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=

# Auth.js v5 — generate with `openssl rand -base64 32`
AUTH_SECRET=

# Local dev: http://localhost:3000  |  Production: the deployed URL
NEXTAUTH_URL=http://localhost:3000

# Postgres (Render for hosted; Docker / local Postgres for dev)
DATABASE_URL=

# Optional: Sentry (set in deploy dashboard, not local)
SENTRY_DSN=
